# Exemplo de variáveis de ambiente do backend (FastAPI + RTDB).
# Copie para .env e ajuste os valores. NÃO comite o .env preenchido.

# Obrigatórias (config/settings.py)
PROJECT_ID=poshbard
RTDB_URL=https://poshbard-default-rtdb.firebaseio.com

# Opcionais
API_PORT=8000
OPENALEX_MAILTO=seu-email@exemplo.com

# Credenciais do Firebase Admin SDK (ver seção "Credenciais" do README).
# Aponte para o JSON de service account OU use `gcloud auth application-default login`.
# Use um caminho válido na SUA máquina (ex.: ./service-account.json).
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# CORS — origens permitidas separadas por vírgula (ver README).
# Se vazio/ausente, o backend libera apenas localhost de desenvolvimento.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
